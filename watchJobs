#!/usr/bin/env python3
"""
Poll LeftClaw Services for research jobs and dispatch the agent.
No LLM involved — pure deterministic loop.
"""

from agent.jobs import JobWatcher

SERVICE_TYPE = 7


def build_prompt(job, attempt, resume):
    job_id = job["id"]
    client = job.get("client", "unknown")

    if resume:
        return (
            f"RESUME: Job #{job_id} on LeftClaw is already assigned to you and IN PROGRESS, "
            f"but was not completed (previous run may have crashed or timed out). "
            f"Do NOT call leftclaw_accept_job — the job is already accepted. "
            f"Use leftclaw_get_job to read the full description, then leftclaw_get_messages to check for client messages. "
            f"Then do thorough research using deep_fetch (8-10 sources max), write a comprehensive report with write_file, "
            f"upload it with bgipfs_upload, log work with leftclaw_log_work (stage 'research'), "
            f"wait 5 seconds, then complete the job with leftclaw_complete_job using the BGIPFS gateway URL."
        )

    if attempt == 1:
        return (
            f"You have a research job to complete. "
            f"Job #{job_id} on LeftClaw Services. Client: {client}. "
            f"Use leftclaw_get_job to read the full description, then leftclaw_get_messages to check for client messages. "
            f"Then do thorough research using deep_fetch (8-10 sources max), write a comprehensive report with write_file, "
            f"upload it with bgipfs_upload, log work with leftclaw_log_work (stage 'research'), "
            f"wait 5 seconds, then complete the job with leftclaw_complete_job using the BGIPFS gateway URL."
        )

    return (
        f"RETRY: Job #{job_id} on LeftClaw was accepted but not completed on a previous attempt. "
        f"The job is already accepted — do NOT call leftclaw_accept_job again. "
        f"Use leftclaw_get_job to read the description, do the research (8-10 sources max), "
        f"write the report, upload to BGIPFS, log work, wait 5 seconds, and complete the job."
    )


if __name__ == "__main__":
    JobWatcher(
        service_type_id=SERVICE_TYPE,
        prompt_builder=build_prompt,
        poll_interval=60,
        agent_timeout=600,
        max_retries=2,
    ).run()
